{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "srim/ai-driven-smart-recruitment",
    "type": "project",
    "description": "AI-Driven Smart Recruitment and Interview Management System Vanilla PHP MVC application.",
    "keywords": ["vanilla-php", "recruitment", "rbac"],
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {},
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
